# Backend API base URL
# In dev: Vite proxies /api -> http://localhost:8001 (see vite.config.ts)
# In prod: set to your backend's full URL if on a different origin
VITE_API_BASE_URL=/api/v1

# Canvas API base — same origin as the rest of the API in dev.
VITE_CANVAS_API_BASE=/api/v1/canvas

# Poll interval (ms) for /session/:id/intent during an active conversation.
VITE_CANVAS_INTENT_POLL_MS=2000
